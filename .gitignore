# Bazel build outputs
bazel-*

# Compiled object files
*.o
*.obj
*.gch
*.pch

# Libraries
*.a
*.so
*.dylib

# Executables
*.out
*.app

# Runtime log files (generated by benchmarks/exchange)
*.log

# macOS metadata
.DS_Store

# Editor files
.vscode/
.idea/
.*.sw?
.sw?

# CLion Bazel plugin
.clwb/

# Claude Code memory
.claude/

# clangd / IDE C++ integration (generated by compile_commands tools)
compile_commands.json

# macOS debug symbol bundles (produced by -g builds)
*.dSYM/

# Crash dumps
core
core.*
